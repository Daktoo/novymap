function dropdownbtu($name, $fakevalue, $value,$img  ) {
	$BTU='<div ';
		$BTU.='type="button" ';
		$BTU.='id="submit-btn" ';
		$BTU.='class="input" ';
		$BTU.="onclick='dropdownclick(\"";
		$BTU.=$name;
		$BTU.="\",\"";
		$BTU.=$fakevalue;
		$BTU.='","';
		$BTU.=$value;
		$BTU.='","';
		$BTU.=$img;
		$BTU.="\")";
		$BTU.="' >";
		$BTU.='<img class="drowdrop-img" src="';
		$BTU.=$img;
		$BTU.='">';
		$BTU.=$fakevalue;
		$BTU.='</div>';
    return $BTU; 
}
$shotallowfile = ['image/bmp','image/webp','image/x-ms-bmp','image/jpeg', 'image/png', 'image/gif'];
$shotallowfiletag = 'accept="';
foreach ($shotallowfile as $ah) {
$shotallowfiletag .= $ah . ', ';
}
