function shothandler($ufile ) {
global $shotallowfile ;
$shotid='No Screenshot';
$fucked="";
$maxFileSize = 20 * 1024 * 1024;
	      if ($ufile['error']=== UPLOAD_ERR_NO_FILE) {
$uploaded=false;
$uploadfailed=false;
		      }elseif ($ufile['size'] > $maxFileSize) {
	      
	    
                        $fucked="File too big !!! ";
$uploaded=true;
			$uploadfailed=true;
	    
		      } elseif (!in_array($ufile["type"], $shotallowfile)) {
	      
	    
                        $fucked="Unsupport file format(only support webp bmp png gif)";
$uploaded=true;
			$uploadfailed=true;
	    
		      }elseif ($ufile['error'] === UPLOAD_ERR_OK ){
			
$uploaded=true;
			$uploadfailed=false;
	    } else {
                        $fucked="Upload failed";
		
$uploaded=true;
			$uploadfailed=true;


	    }
if(!$uploadfailed && $uploaded){
$shotid=substr(hash(hash_algos()[array_rand(hash_algos())],random_bytes(10)),0,100); 
	    $filename="/srv/http/novy/shot2/".$shotid.".png";
		$imagick = new Imagick($ufile["tmp_name"]);
$store=fopen($filename, "w");

if (file_exists($filename)) {

unlink($filename);
}
$imagick->setImageFormat("PNG");
    $imagick->stripImage();
$imagick->writeImage($filename);


}

return [$uploaded,$uploadfailed,$shotid,$fucked];
}

